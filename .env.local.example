# Base URL the browser calls directly (Azure must allow this origin via CORS)
NEXT_PUBLIC_LEADS_API_BASE_URL=https://zelvaa-leads.azurewebsites.net/api

# ---- Azure MSAL Configuration (Entra External ID / CIAM) ----
# App Registration -> Overview -> Application (client) ID
NEXT_PUBLIC_AZURE_CLIENT_ID=PASTE_CLIENT_ID_HERE
# Scope the backend API expects, e.g. api://<api-client-id>/access_as_user
NEXT_PUBLIC_AZURE_BACKEND_SCOPE=api://PASTE_API_CLIENT_ID/access_as_user
# Authority. CIAM: https://<tenant>.ciamlogin.com/<TENANT_ID>
# Single tenant: https://login.microsoftonline.com/<TENANT_ID>
NEXT_PUBLIC_AUTHORITY=https://PASTE_TENANT.ciamlogin.com/PASTE_TENANT_ID
# Must match the SPA redirect URI registered in Azure
NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000
